# ─────────────────────────────────────────────
# PLANEADOR ACADÉMICO — EJEMPLO DE CONFIGURACIÓN
# ─────────────────────────────────────────────
# Copia este archivo como .env y llena los valores
# cp .env.example .env

# Clave secreta de la app (pon cualquier cadena larga y aleatoria)
SECRET_KEY=

# Clave de administrador para configurar la API key desde el navegador
ADMIN_KEY=

# API key de IA (opcional — también se puede configurar desde la app)
AI_API_KEY=
AI_PROVIDER=anthropic
